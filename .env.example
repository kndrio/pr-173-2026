# =============================================================================
# Pedidos Platform — Environment Variables Template
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Security — REQUIRED
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-random-32-char-secret-minimum

# -----------------------------------------------------------------------------
# PostgreSQL — single container, two databases
# -----------------------------------------------------------------------------
POSTGRES_USER=pedidos
POSTGRES_PASSWORD=pedidos123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Auth service connects to auth_db
AUTH_DATABASE_URL=postgresql+asyncpg://pedidos:pedidos123@postgres:5432/auth_db

# Orders service connects to orders_db
ORDERS_DATABASE_URL=postgresql+asyncpg://pedidos:pedidos123@postgres:5432/orders_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# JWT settings
# -----------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Anthropic Claude API (optional — fallback rules used if absent)
# Get your key at https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Redis cache TTL for order listings (seconds)
# -----------------------------------------------------------------------------
REDIS_CACHE_TTL=300
